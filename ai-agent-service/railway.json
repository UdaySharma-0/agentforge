{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "python -m nltk.downloader -d ./nltk_data wordnet omw-1.4"
  },
  "deploy": {
    "runtime": "V2",
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/"
  }
}
